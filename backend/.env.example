# =============================================================================
# CogniCash — Environment Configuration Template
#
# HOW TO USE:
#   1. Copy this file to 'backend/.env'
#   2. Fill in your specific values (especially passwords and secret keys)
#   3. NEVER commit the actual '.env' file to source control.
# =============================================================================

# ── 1. Network & Security ───────────────────────────────────────────────────
# SERVER_ADDR: Internal port for the Go backend.
SERVER_ADDR=:8080

# DOMAIN_NAME: The public domain where this instance is reachable.
# Used by Caddy for automatic HTTPS. Leave as 'localhost' for local testing.
DOMAIN_NAME=localhost

# JWT_SECRET: Random secret used to sign login tokens.
# Run `openssl rand -hex 32` to generate a secure key.
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# ── 2. Authentication (Initial Setup) ───────────────────────────────────────
# These credentials seed the initial admin account ONCE on first startup.[cite: 8]
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME

# ── 3. PostgreSQL Database ──────────────────────────────────────────────────
#
# AUTOMATIC PROVISIONING:[cite: 8]
# When `docker compose up` runs the first time, the postgres image automatically
# creates the user, database, and password defined below.[cite: 8]
#
# DATABASE_HOST must be "postgres" when using Docker Compose.[cite: 8]
DATABASE_HOST=postgres
DATABASE_PORT=5432
POSTGRES_DB=cognicash
POSTGRES_USER=cognicash_user
POSTGRES_PASSWORD=CHANGE_ME

# ── 4. LLM & AI (Ollama) ────────────────────────────────────────────────────
# URL to your Ollama instance.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── 5. Email & Notifications (SMTP) ─────────────────────────────────────────
# Required for Part 3: Password resets and monthly reports.[cite: 1]
SMTP_HOST=smtp.provider.com
SMTP_PORT=587
SMTP_USER=user@provider.com
SMTP_PASSWORD=app-specific-password
SMTP_FROM_EMAIL=noreply@example.com

# ── 6. Bank Integration (Seeding Only) ──────────────────────────────────────
#
# NOTE: These values are used to SEED the initial database settings on the
# first startup. Once the application is running, you can change them via
# the 'Settings' page in the UI, which will overwrite these defaults.
#
# BANK_PROVIDER: 'enablebanking' (default)
BANK_PROVIDER=enablebanking


# --- Enable Banking credentials ---
# Get yours at https://enablebanking.com/
ENABLEBANKING_APP_ID=your_app_id
# Provide the path to your .pem private key file for initial seeding.
ENABLEBANKING_PRIVATE_KEY_PATH=/app/keys/enablebanking_private_key.pem

# ── 7. Automation & Storage ─────────────────────────────────────────────────
# Interval for background workers (Go duration: '1m', '1h', etc.)[cite: 8]
PAYSLIP_IMPORT_INTERVAL=1h
AUTO_CATEGORIZE_INTERVAL=5m

# Path to the JSON manifest inside the container's filesystem.[cite: 8]
PAYSLIP_IMPORT_JSON_PATH=/app/payslips/payslips_import.json